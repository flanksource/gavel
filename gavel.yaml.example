# yaml-language-server: $schema=https://raw.githubusercontent.com/flanksource/gavel/main/gavel.schema.json
# Example `.gavel.yaml` for Gavel.
# See SCHEMA.md and gavel.schema.json for the full field reference.
#
# You can place `.gavel.yaml` in any of these locations:
#   1. ~/.gavel.yaml
#   2. <git-root>/.gavel.yaml
#   3. <target-dir>/.gavel.yaml
#
# Merge order is exactly the list above, with later layers overriding earlier ones.
# Use `gavel config [path]` to inspect the merged result for a specific file or directory.
#
# Merge behavior summary:
#   - Last-write-wins scalars:
#       verify.model, verify.prompt, commit.model, commit.precommit.mode,
#       commit.compatibility.mode, ssh.cmd
#   - Appended lists:
#       verify.checks.disabled, verify.checks.disabledCategories, lint.ignore,
#       commit.hooks, commit.gitignore, commit.allow, pre, post, secrets.configs
#   - Per-linter overrides:
#       lint.linters.<name>.enabled overrides by linter name
#   - Sticky booleans:
#       fixtures.enabled and secrets.disabled stay true once any layer enables them
#   - Replacement lists:
#       fixtures.files replaces the parent layer instead of appending

verify:
  # AI CLI / model selection for `gavel verify`.
  # Common values: claude, gemini, codex, or a fully qualified model name.
  model: claude

  # Optional prompt suffix appended to Gavel's built-in verify prompt.
  # Use this for repo-specific review policy, not for one-off instructions.
  prompt: |
    Prioritize API compatibility, migration safety, and operator-facing errors.
    Flag missing tests for behavior changes and any undocumented config changes.

  checks:
    # Disable individual check IDs emitted by the verify engine.
    disabled:
      - SEC-1
      - PERF-2

    # Disable entire categories of checks.
    # Known categories include: completeness, code-quality, testing,
    # consistency, security, performance.
    disabledCategories:
      - performance

lint:
  # Ignore rules are appended across layers.
  # Each rule may match by source, rule ID, file glob, or any combination.
  ignore:
    - source: golangci-lint
      rule: errcheck
      file: "internal/generated/**"

    - source: eslint
      file: "web/vendor/**"

  linters:
    # Linter enablement is keyed by name and overrides per linter.
    # This is useful for opt-in linters like jscpd or selectively disabling one tool.
    jscpd:
      enabled: true

    vale:
      enabled: false

commit:
  # AI CLI / model selection for `gavel commit`.
  model: claude

  # Hooks run during `gavel commit` before the final commit is written.
  # Hooks are appended across layers in declaration order.
  hooks:
    - name: gofmt
      run: gofmt -w ./...
      files:
        - "**/*.go"

    - name: unit
      run: gavel test --changed
      files:
        - "**/*.go"
        - "**/*.ts"

  # Extra ignore globs applied by `gavel commit` when selecting files to commit.
  # These are appended and deduped across layers.
  gitignore:
    - ".claude/"
    - ".cache/"
    - "dist/"

  # Paths that are allowed through even when broader commit.gitignore globs match.
  # This is useful for generated artifacts you intentionally commit.
  allow:
    - "dist/schema.json"
    - "docs/generated/**"

  precommit:
    # Controls both commit.gitignore prompts and local-path dependency handling
    # for package.json file:/link: refs and go.mod replace directives that
    # point outside the repo.
    # Values:
    #   prompt  ask before committing (default)
    #   fail    hard-fail the commit
    #   skip    bypass both precommit checks
    #   false   alias for skip
    mode: prompt

  compatibility:
    # Controls AI warnings for removed functionality and compatibility issues.
    # Values:
    #   prompt  ask before committing when warnings are present (default)
    #   fail    hard-fail the commit when warnings are present
    #   skip    bypass compatibility AI checks entirely
    #   false   alias for skip
    mode: prompt

fixtures:
  # When true, `gavel test` auto-discovers fixture files.
  enabled: true

  # Files replaces the parent layer instead of appending.
  # If omitted, Gavel falls back to the built-in default: **/*.fixture.md
  files:
    - "tests/**/*.fixture.md"
    - "fixtures/**/*.md"

checks:
  # The post-completion check loop for `gavel todos run --check`. Once an agent
  # reports it is done, gavel runs the configured test/lint suite below; if it
  # fails, gavel feeds a compact failure summary back to the agent and re-runs,
  # looping until the checks pass or maxIterations is reached. Opt-in: the loop
  # runs only when enabled here (or forced on by --check / the dashboard toggle).
  # A TODO's frontmatter `checks:` block overrides these project defaults.
  enabled: true
  # Maximum number of agent re-runs before giving up (default 3).
  maxIterations: 3
  # Omit `test` to skip tests; omit `lint` to skip linting. When the loop is
  # enabled with neither set, it defaults to running both against changed files.
  test:
    changed: true        # only packages affected by the agent's changes
    timeout: 5m          # global wall-clock deadline for the test run
    # paths: ["./pkg/..."]  # restrict to specific package paths
  lint:
    changed: true        # only report new violations vs the base ref
    timeout: 5m          # per-linter deadline
    # linters: ["golangci-lint"]  # restrict to specific linters

ssh:
  # Overrides the command executed by the SSH post-receive hook / push backend.
  # If omitted, the fallback is `gavel test --lint`.
  cmd: gavel test --lint --verify --fixtures

pre:
  # Top-level pre hooks run before the main test/lint pipeline.
  # These are appended across layers and run in declaration order.
  - name: generate
    run: go generate ./...

  - name: deps
    run: make tidy

post:
  # Top-level post hooks run after the main pipeline.
  # These are non-blocking cleanup / reporting hooks.
  - name: summarize
    run: gavel summary --input gavel-results.json --output gavel-summary.md

  - name: cleanup
    run: rm -rf .tmp/gavel

secrets:
  # Set true to disable betterleaks / gitleaks orchestration entirely.
  # This is sticky across layers: once true anywhere, it stays true.
  disabled: false

  # Additional .betterleaks.toml / .gitleaks.toml files to merge in.
  # Relative paths resolve from the directory containing this `.gavel.yaml`.
  configs:
    - ".betterleaks.toml"
    - "security/custom-gitleaks.toml"

procfile:
  # Global defaults for `gavel proc`. Per-process settings (command, default,
  # autoRestart, cpu, mem, profiles, env, maxRestarts) live in the Procfile
  # itself — this section only holds defaults and the active profile.

  # Override Procfile discovery. Relative paths resolve from this file's dir.
  # If omitted, the nearest `Procfile` up to the git root is used.
  path: Procfile

  # Default active profile. A Procfile entry with `profiles` auto-starts only
  # when one of them is active; `gavel proc --profile <name>` overrides this.
  profile: dev

  # Default restart policy for every process. A bool (true=on-failure,
  # false=no) or an enum: no (never), on-failure (non-zero exit), always.
  autoRestart: on-failure

  # Cap automatic restarts per process (0 = unlimited).
  maxRestarts: 5

  # Environment injected into every process, on top of the parent environment
  # and any sibling .env file. Env maps merge key-by-key across layers.
  env:
    RAILS_ENV: development

  # Default resource limits per process. Both are off unless set. A process
  # whose process group exceeds a limit is killed (and restarted per policy).
  #   mem  resident-memory cap (e.g. "512Mi", "2g")
  #   cpu  sustained CPU percentage (100 = one full core)
  mem: 2Gi
  cpu: 400

# Per-process settings live in the Procfile (YAML). A string entry is the
# command (started by default, runs in every profile); an object entry adds
# default/autoRestart/cpu/mem/profiles/env/maxRestarts:
#
#   web: npm start
#   worker:
#     command: rake jobs:work
#     default: false            # registered but not auto-started
#     autoRestart: on-failure   # bool or no|on-failure|always
#     cpu: 100
#     mem: 512Mi
#     maxRestarts: 10
#     env: { WORKER_CONCURRENCY: "4" }
#   mailcatcher:
#     command: mailcatcher
#     profiles: [dev]           # only runs when the dev profile is active
