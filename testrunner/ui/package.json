{
  "name": "@flanksource/gavel",
  "version": "0.1.0",
  "description": "React components and hooks for consuming gavel's testrunner real-time test progress UI.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flanksource/gavel.git",
    "directory": "testrunner/ui"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist/lib",
    "README.md"
  ],
  "main": "./dist/lib/index.cjs",
  "module": "./dist/lib/index.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js",
      "require": "./dist/lib/index.cjs"
    },
    "./testrunner": {
      "types": "./dist/lib/testrunner.d.ts",
      "import": "./dist/lib/testrunner.js",
      "require": "./dist/lib/testrunner.cjs"
    },
    "./testrunner/hooks": {
      "types": "./dist/lib/hooks.d.ts",
      "import": "./dist/lib/hooks.js",
      "require": "./dist/lib/hooks.cjs"
    },
    "./testrunner/types": {
      "types": "./dist/lib/types.d.ts",
      "import": "./dist/lib/types.js",
      "require": "./dist/lib/types.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "build:lib": "vite build -c vite.lib.config.ts && vite build -c vite.lib.config.ts --mode cjs",
    "dev": "vite",
    "test": "vitest run",
    "check": "tsc -p tsconfig.lib.json --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.66.8"
  },
  "peerDependencies": {
    "@flanksource/clicky-ui": "^0.2.4",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@flanksource/clicky-ui": "^0.2.4",
    "@preact/preset-vite": "^2.9.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "preact": "^10.25.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.3.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.0"
  }
}
